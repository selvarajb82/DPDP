# =====================================================
# DPDP Compliance Checker — Environment Variables
# Copy to .env and fill in your values
# =====================================================

# Database
POSTGRES_PASSWORD=your_secure_password_here
DATABASE_URL=postgresql://dpdp_user:your_secure_password_here@localhost:5432/dpdp_checker

# AI — currently using OpenAI (switch to Anthropic when credits are ready)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Anthropic (for future switch-back to Claude)
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-20250514

# Razorpay
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# n8n Webhooks (your Hostinger VPS n8n instance)
N8N_PAYMENT_WEBHOOK_URL=https://your-n8n.vtogether.tech/webhook/payment-confirmation
N8N_REPORT_WEBHOOK_URL=https://your-n8n.vtogether.tech/webhook/report-ready

# Flask
SECRET_KEY=generate_a_long_random_string_here
FLASK_ENV=production
FRONTEND_URL=https://dpdp.vtogether.tech
BACKEND_URL=https://dpdp.vtogether.tech

# Frontend (set during Docker build)
VITE_API_URL=https://dpdp.vtogether.tech
